{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PearTree",
  "version": "0.1.0",
  "identifier": "network.artic.peartree",
  "build": {
    "frontendDist": "../peartree"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; script-src 'self' 'unsafe-inline' asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc://localhost https: http: asset: https://asset.localhost; img-src 'self' data: blob: asset: https://asset.localhost; worker-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Phylogenetic Tree Viewer",
    "longDescription": "PearTree is a fast, interactive phylogenetic tree viewer for genomic epidemiology.",
    "macOS": {
      "infoPlist": "./Info.plist"
    },
    "fileAssociations": [
      {
        "ext": ["tree", "tre", "nex", "nexus", "treefile", "nwk", "newick"],
        "name": "PearTree phylogenetic tree file"
      }
    ]
  },
    "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": []
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzMTMyNjVCMDAwOEEwNDMKUldSRG9BZ0FXeVlUOHd4NGlhb28yTTRGM0xGaXZEWmg4UlB4Z0ZlR04wSWNNc0tXZGQ2NkNPK28K",
      "endpoints": [
        "https://github.com/artic-network/peartree/releases/latest/download/latest.json"
      ]
    }
  }
}
