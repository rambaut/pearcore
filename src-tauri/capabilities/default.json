{
  "identifier": "default",
  "description": "Default capability for PearTree – grants core APIs to the main window.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:webview:allow-print",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "updater:default"
  ]
}
